async function _saOpenTopup(merchantId, currentCredits) {
  const input = prompt(`💰 为商家 [${merchantId}] 充值\n当前余额: ${currentCredits}\n\n请输入充值数额（credits）:`, '50');
  if (!input || isNaN(parseFloat(input))) { showToast('已取消或输入无效', 'info'); return; }
  const amount = parseFloat(input);
  if (amount <= 0) { showToast('数额必须大于0', 'error'); return; }

  const fb = window.__lbFirebase;
  if (!fb?.db) { showToast('Firestore 未就绪', 'error'); return; }
  try {
    const ref = fb.doc(fb.db, 'merchants', merchantId);
    await fb.runTransaction(fb.db, async (tx) => {
      const snap = await tx.get(ref);
      const cur = Number(snap.data()?.credits) || 0;
      tx.update(ref, { credits: cur + amount, updatedAt: new Date().toISOString() });
    });
    showToast(`✅ 充值成功！+${amount} credits`, 'success');
    await _loadSuperAdminMerchants();
  } catch(e) {

    showToast('充值失败：' + e.message, 'error');
  }
}

